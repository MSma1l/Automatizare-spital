# Force LF line endings for shell scripts and Docker files.
# Without this, a git clone on Windows with autocrlf=true converts .sh files
# to CRLF, which makes bash crash inside Linux containers with errors like:
#   /usr/bin/env: 'bash\r': No such file or directory
#   ./entrypoint.sh: line 2: $'\r': command not found
*.sh              text eol=lf
*.bash            text eol=lf
Dockerfile        text eol=lf
Dockerfile.*      text eol=lf
*.dockerfile      text eol=lf
docker-compose*.yml  text eol=lf
nginx.conf        text eol=lf
*.conf            text eol=lf

# Normal text files — honour autocrlf
*.py              text
*.ts              text
*.tsx             text
*.js              text
*.jsx             text
*.json            text
*.md              text
*.yml             text
*.yaml            text
*.html            text
*.css             text

# Binary — never touch
*.png             binary
*.jpg             binary
*.jpeg            binary
*.pkl             binary
*.ico             binary
